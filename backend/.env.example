# Backend Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# ─── Database (NeonDB PostgreSQL) ─────────────────────────────────
# Get from: https://neon.tech/
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/doctor_appointment?sslmode=require

# ─── JWT Authentication ───────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Must be at least 32 characters long
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars

# Token expiry in hours
TOKEN_EXPIRE_HOURS=24

# ─── CORS Configuration ───────────────────────────────────────────
# Your deployed frontend URL
# For local development:
FRONTEND_URL=http://localhost:3000
NEXT-PUBLIC-API_URL=http://localhost:8000/api
# For production (Vercel):
FRONTEND_URL=https://doctor-appointment-management-sytem.vercel.app

# ─── AI Chatbot (Groq) ────────────────────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_api_key_here

# Groq model to use
GROQ_MODEL=llama-3.1-8b-instant

# Alternative AI providers (optional)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here

# ─── Email Notifications (Resend) ─────────────────────────────────
# Get from: https://resend.com/api-keys
# Free tier: 3,000 emails/month
RESEND_API_KEY=re_your_api_key_here

# Verified sender email (must be verified in Resend dashboard)
FROM_EMAIL=appointments@yourdomain.com

# ─── File Upload ──────────────────────────────────────────────────
# Directory for storing uploaded profile photos
UPLOAD_DIR=uploads

# ─── Production Checklist ─────────────────────────────────────────
# [ ] Set strong SECRET_KEY (min 32 chars)
# [ ] Configure DATABASE_URL from NeonDB
# [ ] Set FRONTEND_URL to your Vercel URL
# [ ] Add GROQ_API_KEY from Groq console
# [ ] Add RESEND_API_KEY and verify FROM_EMAIL
# [ ] Test all features in production
# [ ] Enable HTTPS on all services
